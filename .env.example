# ============================================
# NVIDIA AI CONFIGURATION
# ============================================
# Dapatkan API Key di: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-masukkan_api_key_anda_disini

# Model default (bisa diganti sesuai katalog Nvidia)
# Pilihan: minimaxai/minimax-m3, meta/llama-3.1-405b-instruct, mistralai/mistral-large, dll
NVIDIA_MODEL=minimaxai/minimax-m3

# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
# Dapatkan token dari @BotFather di Telegram
# 1. Buka Telegram dan cari @BotFather
# 2. Kirim /newbot dan ikuti instruksinya
# 3. Salin token yang diberikan
TELEGRAM_BOT_TOKEN=masukkan_telegram_bot_token_anda_disini

# ============================================
# WHATSAPP CONFIGURATION
# ============================================
# Folder untuk menyimpan auth state WhatsApp
# Jangan commit folder ini ke git!
WHATSAPP_AUTH_FOLDER=./whatsapp-auth